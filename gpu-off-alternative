#!/bin/bash
# ACPI GPU OFF (firmware power gating via acpi_call)

LOGTAG="gpu-off"

echo "[$(date)] starting GPU ACPI power-off sequence" >> /tmp/gpu_status.log

# Ensure module is loaded
modprobe acpi_call 2>/dev/null

# Wait for /proc interface to appear
for i in {1..5}; do
    [ -e /proc/acpi/call ] && break
    sleep 1
done

if [ ! -e /proc/acpi/call ]; then
    echo "[$(date)] ERROR: /proc/acpi/call not found" >> /tmp/gpu_status.log
    exit 1
fi

# Try known AMD ACPI power-off methods
METHODS=(
    '\_SB.PCI0.PEG0.PEGP._OFF'
    '\_SB.PCI0.PEG0.PEGP.SGOF'
)

for i in {1..3}; do
    for m in "${METHODS[@]}"; do
        echo "$m" > /proc/acpi/call 2>/dev/null
        echo "[$(date)] attempted $m result=$(cat /proc/acpi/call 2>/dev/null)" >> /tmp/gpu_status.log
    done
    sleep 1
done

echo "[$(date)] GPU ACPI sequence completed" >> /tmp/gpu_status.log
